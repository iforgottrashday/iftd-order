{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://www.iforgottrashday.com https://*.wixsite.com https://*.wix.com"
        }
      ]
    }
  ]
}
